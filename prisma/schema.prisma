generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TENANT
  MANAGER
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AiPriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum RentStatus {
  PENDING
  PAID
  LATE
  PARTIAL
}

model User {
  id                   String               @id @default(uuid())
  full_name            String
  email                String               @unique
  password_hash        String
  role                 UserRole
  created_at           DateTime             @default(now())
  maintenanceRequests  MaintenanceRequest[] @relation("TenantRequests")
  messages             Message[]
  leases               Lease[]              @relation("TenantLeases")
}

model Property {
  id           String   @id @default(uuid())
  name         String
  address      String
  monthly_rent Float
  created_at   DateTime @default(now())
  leases       Lease[]
}

model Lease {
  id           String        @id @default(uuid())
  tenant_id    String
  property_id  String
  rent_amount  Float
  due_day      Int
  active       Boolean       @default(true)
  created_at   DateTime      @default(now())
  tenant       User          @relation("TenantLeases", fields: [tenant_id], references: [id], onDelete: Cascade)
  property     Property      @relation(fields: [property_id], references: [id], onDelete: Cascade)
  rentPayments RentPayment[]

  @@index([tenant_id, active])
  @@index([property_id])
}

model RentPayment {
  id         String     @id @default(uuid())
  lease_id    String
  amount      Float
  due_date    DateTime
  paid_date   DateTime?
  status      RentStatus @default(PENDING)
  method      String?
  note        String?
  created_at  DateTime   @default(now())
  lease       Lease      @relation(fields: [lease_id], references: [id], onDelete: Cascade)

  @@index([lease_id, due_date])
  @@index([status, due_date])
}

model MaintenanceRequest {
  id                    String         @id @default(uuid())
  tenant_id             String
  title                 String
  description           String
  category              String?
  user_reported_urgency Int?
  status                RequestStatus  @default(OPEN)
  image_url             String?
  manager_note          String?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  ai_category           String?
  ai_priority           AiPriority?
  ai_summary            String?
  ai_recommended_action String?
  ai_response_draft     String?
  ai_escalated          Boolean        @default(false)
  ai_confidence_score   Float?

  tenant                User           @relation("TenantRequests", fields: [tenant_id], references: [id], onDelete: Cascade)
  messages              Message[]
}

model Message {
  id                     String             @id @default(uuid())
  maintenance_request_id String
  sender_id              String
  body                   String
  created_at             DateTime           @default(now())
  read_at                DateTime?

  maintenanceRequest     MaintenanceRequest @relation(fields: [maintenance_request_id], references: [id], onDelete: Cascade)
  sender                 User               @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([maintenance_request_id, created_at])
  @@index([sender_id])
}

model FaqEntry {
  id         String   @id @default(uuid())
  question   String
  answer     String
  category   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
