generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TENANT
  MANAGER
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id            String        @id @default(uuid())
  full_name     String
  email         String        @unique
  password_hash String
  role          UserRole
  created_at    DateTime      @default(now())

  // Relations
  maintenanceRequests MaintenanceRequest[] @relation("TenantRequests")
}

model MaintenanceRequest {
  id               String      @id @default(uuid())
  tenant_id        String
  title            String
  description      String
  category         String?
  user_reported_urgency Int?
  status           RequestStatus @default(OPEN)
  image_url        String?
  created_at       DateTime    @default(now())

  // AI fields
  ai_category            String?
  ai_priority            String?
  ai_summary             String?
  ai_recommended_action  String?
  ai_response_draft      String?
  ai_escalated           Boolean     @default(false)
  ai_confidence_score    Float?

  // Relation back to tenant
  tenant          User @relation("TenantRequests", fields: [tenant_id], references: [id])
}

model FaqEntry {
  id        String   @id @default(uuid())
  question  String
  answer    String
  category  String?
}
