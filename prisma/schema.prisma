generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TENANT
  MANAGER
}

enum RequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum AiPriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

model User {
  id                   String               @id @default(uuid())
  full_name            String
  email                String               @unique
  password_hash        String
  role                 UserRole
  created_at           DateTime             @default(now())
  maintenanceRequests  MaintenanceRequest[] @relation("TenantRequests")
  messages             Message[]
}

model MaintenanceRequest {
  id                    String         @id @default(uuid())
  tenant_id             String
  title                 String
  description           String
  category              String?
  user_reported_urgency Int?
  status                RequestStatus  @default(OPEN)
  image_url             String?
  manager_note          String?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  ai_category           String?
  ai_priority           AiPriority?
  ai_summary            String?
  ai_recommended_action String?
  ai_response_draft     String?
  ai_escalated          Boolean        @default(false)
  ai_confidence_score   Float?

  tenant                User           @relation("TenantRequests", fields: [tenant_id], references: [id], onDelete: Cascade)
  messages              Message[]
}

model Message {
  id                     String             @id @default(uuid())
  maintenance_request_id String
  sender_id              String
  body                   String
  created_at             DateTime           @default(now())
  read_at                DateTime?

  maintenanceRequest     MaintenanceRequest @relation(fields: [maintenance_request_id], references: [id], onDelete: Cascade)
  sender                 User               @relation(fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([maintenance_request_id, created_at])
  @@index([sender_id])
}

model FaqEntry {
  id         String   @id @default(uuid())
  question   String
  answer     String
  category   String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
